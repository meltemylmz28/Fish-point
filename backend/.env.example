# Copy this file to .env and fill in your real values

# Backend development server settings
DJANGO_PRODUCTION=False
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Email configuration for verification and password reset.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@fishpoint.local
# For SMTP, set EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend and fill the values below.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# Social auth client IDs
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=com.yourcompany.yourapp
